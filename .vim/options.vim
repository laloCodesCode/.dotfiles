filetype plugin indent on
set softtabstop=4
set smartindent
set showmatch 
syntax on

set number
set relativenumber
set noshowmode

set clipboard=unnamedplus



set tabstop=4
set shiftwidth=4
set autoindent
set expandtab



set ignorecase
set smartcase
set incsearch

set background=dark
set signcolumn=yes
set cursorline
set colorcolumn=80

set backspace=indent,eol,start


set splitbelow
set splitright

set iskeyword+=-

set scrolloff=8

set updatetime=50


